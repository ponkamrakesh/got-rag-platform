# === PIPELINE / AUTOMATION ===
# Intermediate processed JSONL files (large, rebuildable)
/data/processed/

# Extracted images ARE committed so Vercel serves them statically.
# If your repo grows >100MB, switch to Git LFS or external CDN.
# Do NOT uncomment the line below.
# /public/extracted/

# Eval results ARE committed so the Vercel dashboard can read them.
# /eval/results.json

# Ingestion state hash file IS committed so CI knows what changed.
# /data/.ingestion_state.json

# PDFs: commit them if repo size allows, otherwise use Git LFS or cloud storage.
# /data/pdfs/
